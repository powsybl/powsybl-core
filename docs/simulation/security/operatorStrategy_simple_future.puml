@startuml

'namespace mvp {

namespace existing {

class OperatorStrategy {
  - String id
  - ContingencyContext contingencyContext
  - List<ConditionalActions> conditionalActions
}
OperatorStrategy --* "1" ContingencyContext
OperatorStrategy --* "*" ConditionalActions

class ConditionalActions {
  - List<String> actionIds
  - Condition condition
  - Optional<Integer> applicationDelay
}
ConditionalActions ..* "*" Action
ConditionalActions --* "1" Condition
note right of ConditionalActions::applicationDelay
  new field
end note

interface Condition
Condition <|-- AndCondition
Condition <|-- OrCondition

class AndCondition {
  + Set<Condition> conditions
}

class OrCondition {
  + Set<Condition> conditions
}

class ContingencyContext {
  - ContingencyContextType contextType
}
ContingencyContext --* "1" ContingencyContextType


enum ContingencyContextType {
  ALL
  NONE
  SPECIFIC
  ONLY_CONTINGENCIES
}

interface Action {
  + getId()
  + getType()
  + NetworkModification toModification()
}

'end namespace existing
}

Condition <|-- AnyViolationInCountryCondition


class AnyViolationInCountryCondition {
 + Country country
 + Set<LimitViolationType> conditionFilters
}
note right: condition filter or branch threshold ?

class OptimizableRemedialAction {
  - String id
  - Condition condition
  - ContingencyContext contingencyContext
  - Optional<Integer> applicationDelay
}
OptimizableRemedialAction --* "1" Condition
OptimizableRemedialAction --* "1" ContingencyContext
OptimizableRemedialAction <|-- BinaryRemedialAction
OptimizableRemedialAction <|-- RangeRemedialAction

class BinaryRemedialAction {
  - Set<Action> actions
  + Set<Action> toActions()
}
BinaryRemedialAction --* "*" Action

class RangeRemedialAction {
  - Range range
  - Set<RangeAction> rangeActions
  + Set<Action> toActions(double setPoint)
}
RangeRemedialAction --* "*" RangeAction

interface Range {
 - boolean isRelative
 - Optional<Double> mimimum
 - Optional<Double> maximum
}
note right of Range::isRelative
 Notion similaire mais valeur différente de isRelativeValue dans les actions
end note

interface RangeAction {
  - Set<Range> ranges
  - boolean isIntegerValue
  + Action toAction(double setPoint)
}
RangeAction --* "*" Range
'note bottom: Clone of some actions but without "set point"

interface DiscreteRangeAction {
}
DiscreteRangeAction --|> RangeAction

class AbstractTapChangerRegulationAction {

}
PhaseTapChangerTapPositionRangeAction --|> DiscreteRangeAction

interface ContinuousRangeAction {
}
ContinuousRangeAction --|> RangeAction

class LoadRangeAction {
 - double pMin
 - double pMax
 + LoadAction toAction(double setPoint)
}
LoadRangeAction --|> ContinuousRangeAction




interface SetpointBasedAction {
}
SetpointBasedAction --|> Action

class AbstractLoadAction {
}
AbstractLoadAction --|> SetpointBasedAction

class MultipleActionWithKey {
}
MultipleActionWithKey --|> SetpointBasedAction
'end namespace mvp
'}

namespace niceToHave {
class ExclusiveOptimizableRemedialActionGroup {
  - List<String> exclusiveRemedialActionIds
  - int limitOfSelectedRemedialActions
}
ExclusiveOptimizableRemedialActionGroup ..* "*" OptimizableRemedialAction

class TemporalRangeRemedialAction {
  - Set<TemporalRangeAction> temporalRangeActions
  + Set<Action> toActions(ZonedDateTime caseDate, double setPoint)
}
TemporalRangeRemedialAction --* "*" TemporalRangeAction
TemporalRangeRemedialAction --|> OptimizableRemedialAction

interface TemporalRangeAction {
    + Action toAction(ZonedDateTime caseDate, double setPoint)
}
note right: Clone of some range actions but with a case date
}


@enduml