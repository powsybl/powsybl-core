@startuml

class OperatorStrategy {
  - ContingencyContext contingencyContext
  - List<ConditionalActions> conditionalActions
}
OperatorStrategy --* ContingencyContext
OperatorStrategy --* "*" ConditionalActions

interface Condition
Condition <|-- AndCondition
Condition <|-- OrCondition
Condition <|-- AnyViolationInCountryCondition

class AndCondition {
  + Set<Condition> conditions
}

class OrCondition {
  + Set<Condition> conditions
}

class AnyViolationInCountryCondition {
 + Country country
 + Set<LimitViolationType> conditionFilters (ou branch threshold ?)
}


class ConditionalActions {
  - List<String> actionIds
  - Condition condition
}
ConditionalActions ..* Action


class ContingencyContext {
  - Optional<Integer> applicationDelay
}
ContingencyContext --* "1" ContingencyContextType

enum ContingencyContextType {
  ALL
  NONE
  SPECIFIC
  ONLY_CONTINGENCIES
}

interface Action {
 + NetworkModification toModification()
}

class OptimizableRemedialAction {
  - Condition condition
  - ContingencyContext contingencyContext
}
OptimizableRemedialAction --* Condition
OptimizableRemedialAction --* "1" ContingencyContext
OptimizableRemedialAction <|-- BinaryRemedialAction
OptimizableRemedialAction <|-- RangeRemedialAction

class BinaryRemedialAction {
  - Set<Action> actions
  + Set<Action> toActions()
  + OperatorStrategy toOperatorStrategy()
}
BinaryRemedialAction --* "*" Action

class RangeRemedialAction {
  - Set<RangeAction> rangeActions
  + RangeType rangeType
  + Set<Action> toActions(double setPoint)
  + OperatorStrategy toOperatorStrategy(double setPoint)
}
RangeRemedialAction --* "*" RangeAction
RangeRemedialAction --* "1" RangeType

enum RangeType {
  DISCRETE
  CONTINUOUS
}

interface RangeAction {
  + Action toAction(double setPoint)
}
note bottom: Clone des actions mais sans "set point"




@enduml