<xs:schema version="1.0"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:lmc="http://www.powsybl.org/schema/iidm/ext/line_couplings/1_0"
           targetNamespace="http://www.powsybl.org/schema/iidm/ext/line_couplings/1_0"
           elementFormDefault="qualified">
    <xs:simpleType name='nonEmptyString'>
        <xs:restriction base='xs:string'>
            <xs:minLength value='1'/>
        </xs:restriction>
    </xs:simpleType>
    <xs:element name="lineCouplings">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="mutualCoupling" maxOccurs="unbounded">
                    <xs:complexType>
                        <xs:attribute name="line1" use="required" type="lmc:nonEmptyString"/>
                        <xs:attribute name="line2" use="required" type="lmc:nonEmptyString"/>
                        <xs:attribute name="r" use="required" type="xs:double"/>
                        <xs:attribute name="x" use="required" type="xs:double"/>
                        <xs:attribute name="line1Start" type="xs:double"/>
                        <xs:attribute name="line2Start" type="xs:double"/>
                        <xs:attribute name="line1End" type="xs:double"/>
                        <xs:attribute name="line2End" type="xs:double"/>
                    </xs:complexType>
                </xs:element>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
</xs:schema>
